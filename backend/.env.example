# Database Configuration
# Use this format for local PostgreSQL: postgresql://user:password@localhost:5432/synergex_med
# For Railway, Render, or other services, they provide the connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/synergex_med

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email Configuration (optional, for future notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ADMIN_EMAIL=admin@synergex-med.com
